{
  "name": "@aegis/config",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Shared TS config + validated environment schema for the Aegis monorepo",
  "exports": {
    "./tsconfig.base.json": "./tsconfig.base.json",
    "./env": {
      "types": "./dist/env.d.ts",
      "import": "./dist/env.js"
    }
  },
  "scripts": {
    "build": "tsup src/env.ts --format esm --dts --clean",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
