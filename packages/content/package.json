{
  "name": "@aegis/content",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Framework + control library as content-as-data (EU AI Act, NIST AI RMF, crosswalks, questionnaires)",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@aegis/config": "workspace:*",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
