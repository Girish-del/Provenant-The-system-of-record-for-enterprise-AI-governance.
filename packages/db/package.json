{
  "name": "@aegis/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "generate": "prisma generate",
    "migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "migrate:deploy": "dotenv -e ../../.env -- prisma migrate deploy",
    "db:push": "dotenv -e ../../.env -- prisma db push --skip-generate",
    "rls:apply": "dotenv -e ../../.env -- node scripts/apply-rls.mjs",
    "db:setup": "pnpm run db:push && pnpm run rls:apply",
    "db:seed": "dotenv -e ../../.env -- tsx --import ./scripts/seed-env.mjs src/seed.ts",
    "test": "dotenv -e ../../.env -- vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aegis/content": "workspace:*",
    "@prisma/client": "^6.1.0"
  },
  "devDependencies": {
    "@aegis/config": "workspace:*",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "pg": "^8.13.1",
    "prisma": "^6.1.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "dotenv-cli": "^8.0.0"
  }
}
