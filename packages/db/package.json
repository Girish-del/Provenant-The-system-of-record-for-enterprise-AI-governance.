{
  "name": "@aegis/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "generate": "prisma generate",
    "migrate": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma db push --skip-generate",
    "rls:apply": "node scripts/apply-rls.mjs",
    "db:setup": "prisma db push && node scripts/apply-rls.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0"
  },
  "devDependencies": {
    "@aegis/config": "workspace:*",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "pg": "^8.13.1",
    "prisma": "^6.1.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
