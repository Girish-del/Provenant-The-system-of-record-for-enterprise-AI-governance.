# Copy to .env and fill in. Never commit .env. Validated at boot by @aegis/config (env).
# Dev defaults below match docker-compose.yml.

NODE_ENV=development

# --- Core data stores ---
# In dev the `aegis` superuser is fine. In M2 we add a non-superuser app role
# (no BYPASSRLS) so Row-Level Security actually applies — see packages/db.
DATABASE_URL=postgresql://aegis:aegis@localhost:5432/aegis
REDIS_URL=redis://localhost:6379

# --- App URLs ---
WEB_URL=http://localhost:3000
API_URL=http://localhost:3001
AI_SERVICE_URL=http://localhost:8000

# --- Object storage (LocalStack S3 in dev) ---
S3_ENDPOINT=http://localhost:4566
S3_REGION=eu-central-1
S3_BUCKET=aegis-evidence
S3_ACCESS_KEY_ID=test
S3_SECRET_ACCESS_KEY=test

# --- Security ---
# 32+ chars. Generate a real one for any shared/deployed env.
SESSION_SECRET=dev-only-insecure-change-me-0123456789abcd

# --- Auth: WorkOS (optional in dev; dev auth provider is used until set) ---
WORKOS_API_KEY=
WORKOS_CLIENT_ID=

# --- AI: Anthropic (needed once the AI service is wired, M9) ---
ANTHROPIC_API_KEY=

# --- Commercial / ops (needed at their components: M14/M15) ---
STRIPE_SECRET_KEY=
RESEND_API_KEY=
SENTRY_DSN=
POSTHOG_KEY=
