# Copy to .env and fill in. Never commit .env. Validated at boot by @aegis/config (env).
# Dev defaults below match docker-compose.yml.

NODE_ENV=development

# --- Core data stores ---
# App runtime connects as the non-superuser role `aegis_app` so RLS is enforced.
# `aegis_app` is created by packages/db/prisma/rls.sql (rls:apply).
DATABASE_URL=postgresql://aegis_app:aegis_app@localhost:5432/aegis
# Migrations + RLS setup run as the owner/superuser `aegis` (docker-compose default).
DIRECT_URL=postgresql://aegis:aegis@localhost:5432/aegis
REDIS_URL=redis://localhost:6379

# --- App URLs ---
WEB_URL=http://localhost:3000
API_URL=http://localhost:3001
AI_SERVICE_URL=http://localhost:8000

# --- Object storage (LocalStack S3 in dev) ---
S3_ENDPOINT=http://localhost:4566
S3_REGION=eu-central-1
S3_BUCKET=aegis-evidence
S3_ACCESS_KEY_ID=test
S3_SECRET_ACCESS_KEY=test

# --- Security ---
# 32+ chars. Generate a real one for any shared/deployed env.
SESSION_SECRET=dev-only-insecure-change-me-0123456789abcd

# --- Auth: WorkOS (optional in dev; dev auth provider is used until set) ---
# Enables /auth/sso/login (Google OAuth + enterprise SSO). Placeholders:
# WORKOS_API_KEY=sk_test_xxx  WORKOS_CLIENT_ID=client_xxx
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
WORKOS_REDIRECT_URI=http://localhost:3001/auth/sso/callback

# --- AI: Anthropic (needed once the AI service is wired, M9) ---
ANTHROPIC_API_KEY=
# AI cost controls (M16) — all optional; dev defaults are permissive.
# Per-org daily token budget (0/unset = unlimited), response-cache TTL seconds
# (0 disables), circuit-breaker failure threshold + cooldown seconds.
AI_DAILY_TOKEN_BUDGET=
AI_CACHE_TTL_SECONDS=
AI_BREAKER_THRESHOLD=
AI_BREAKER_COOLDOWN_SECONDS=
# Model routing per task (defaults: draft=claude-sonnet-4-0, suggest=claude-haiku-4-5)
ANTHROPIC_MODEL_DRAFT=
ANTHROPIC_MODEL_SUGGEST=

# --- Internal service auth: core API -> AI service (X-Internal-Token) ---
# Generate any long random string; set the SAME value for both services.
INTERNAL_API_TOKEN=

# --- Commercial / ops (needed at their components: M14/M15) ---
# Stripe (B8): without keys the mock checkout + dev set-plan path is used.
# Placeholders: sk_test_xxx / whsec_xxx / price_xxx from the Stripe dashboard.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_TEAM=
STRIPE_PRICE_BUSINESS=
RESEND_API_KEY=
SENTRY_DSN=
POSTHOG_KEY=
# OpenTelemetry (B9): OTLP HTTP endpoint, e.g. http://localhost:4318 — noop unset.
OTEL_EXPORTER_OTLP_ENDPOINT=
# Review-workflow SLA in days for B6 step due dates (default 5).
REVIEW_SLA_DAYS=
# AI budgets can use a dedicated redis (falls back to REDIS_URL, then in-memory).
AI_BUDGET_REDIS_URL=
# Optional overrides (defaults: EU PostHog host; Aegis dev sender)
POSTHOG_HOST=
EMAIL_FROM=
